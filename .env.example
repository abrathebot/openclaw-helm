# OpenClaw Deploy Configuration
# Copy this file to .env (or openclaw.env) and fill in your values.
# CLI flags always override .env values.
#
# Usage:
#   cp .env.example .env
#   # edit .env
#   ./deploy.sh          # or: curl .../deploy.sh | bash

# ── Instance ──────────────────────────────────────────────────────────────────
# NOTE: Instance name is NOT set here — pass it when calling the script:
#   ./deploy.sh mybot
#   ./deploy.sh raya-bot
OPENCLAW_HOST=ai.example.com          # public hostname (without https://)
# OPENCLAW_PORT=3001                   # host port (auto-detect if empty)
# OPENCLAW_MODE=docker                 # docker | helm
# OPENCLAW_IMAGE=ghcr.io/abrathebot/openclaw:latest

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Option A: Tunnel token (zero-config — recommended for new deployments)
#   Get yours: Cloudflare Zero Trust → Tunnels → Create a tunnel → copy token
CF_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# Option B: Point to existing cloudflared config (if you already have one)
# CF_CONFIG=/home/user/.cloudflared/my-tunnel.yml

# Option C: Skip tunnel entirely (access via port-forward only)
# NO_TUNNEL=true

# ── Features ──────────────────────────────────────────────────────────────────
# OPENCLAW_DATA_DIR=mybot-data          # Docker volume name or absolute path
# OPENCLAW_NAMESPACE=openclaw           # Helm namespace (helm mode only)
